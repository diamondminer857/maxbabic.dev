---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const formatDate = (date: Date) =>
  date.toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
---

<Layout current="blog" title="Blog — maxbabic.dev">
  <section>
    <div class="section-head">
      <h2 class="section-title">All <em>posts</em></h2>
      <span class="section-num">/ 01</span>
    </div>

    <div class="posts">
      {posts.map((post) => (
        <a href={`/blog/${post.id}`} class="post-card">
          <span class="post-date">{formatDate(post.data.date)}</span>
          <span class="post-title">{post.data.title}</span>
          {post.data.tag && <span class="post-tag">{post.data.tag}</span>}
        </a>
      ))}
    </div>
  </section>
</Layout>
